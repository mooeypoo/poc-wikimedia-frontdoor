# Wikimedia OAuth 2.0 (docs/adr-wikimedia-oauth-authentication.md).
# Copy this file to .env and fill in real values. Never commit .env.

# 32-byte secret used to encrypt the transient PKCE handshake cookie (h3.useSession).
# Generate one with: openssl rand -base64 32
NUXT_OAUTH_COOKIE_SECRET=

# client_id from the approved Wikimedia OAuth 2.0 consumer registration
# (https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration/propose/oauth2).
NUXT_PUBLIC_OAUTH_CLIENT_ID=
