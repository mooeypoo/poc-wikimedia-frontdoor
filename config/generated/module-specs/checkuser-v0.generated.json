	"paths": {
		"/batch-temporaryaccount": {
			"post": {
				"description": "Batch retrieve IP addresses mapped to temporary accounts and their revision/log/abuse filter IDs.",
				"operationId": "postBatchRetrieveIpAddressesForTemporaryAccounts",
				"parameters": [],
				"requestBody": {
					"content": {
						"application/json": {
							"example": {
								"token": "missing_example",
								"users": "missing_example"
							},
							"schema": {
								"properties": {
									"token": {
										"default": "",
										"description": "token parameter",
										"type": "string"
									},
									"users": {
										"additionalProperties": {
											"additionalProperties": false,
											"properties": {
												"abuseLogIds": {
													"items": {
														"type": "string"
													},
													"type": "array"
												},
												"lastUsedIp": {
													"type": "boolean"
												},
												"logIds": {
													"items": {
														"type": "string"
													},
													"type": "array"
												},
												"revIds": {
													"items": {
														"type": "string"
													},
													"type": "array"
												}
											},
											"required": [
												"revIds",
												"logIds",
												"lastUsedIp"
											],
											"type": "object"
										},
										"description": "users parameter",
										"type": "object"
									}
								},
								"required": [
									"users"
								],
								"type": "object"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK",
						"headers": {
							"Cache-Control": {
								"description": "Dictates caching behavior for a browser, letting it know how often to refresh locally stored resources.",
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"$ref": "#/components/responses/GenericErrorResponse"
					}
				},
				"security": [
					{
						"CentralAuthSessionProvider-Session": [],
						"CentralAuthSessionProvider-Token": [],
						"CentralAuthSessionProvider-UserID": []
					}
				],
				"summary": "Batch retrieve IP addresses for temporary accounts"
			}
		},
